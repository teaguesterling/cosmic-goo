#!/usr/bin/env bash
# bin/goo — cosmic-goo CLI entry point.
#
# Usage:
#   goo                                # opens the compose dialog (picker-driven)
#   goo <verb> [POSITIONAL...] [--adverb=VALUE]
#   goo list <source>                  # raw JSON of source items
#   goo describe <verb>                # show verb's accepts, adverbs, template
#   goo compose                        # pick subject → verb → object → adverbs
#   goo plugins                        # list loaded plugins
#   goo validate                       # check all plugins for errors
#   goo -h | --help                    # this message

# Resolve repo root from script location. Follow symlinks first so a
# `~/.local/bin/goo -> /path/to/cosmic-goo/bin/goo` install still finds
# its sibling lib/ and plugins/ directories.
# Don't set -e: we use explicit error handling so verb_lookup misses
# etc. don't accidentally abort the script.
set -uo pipefail
GOO_DIR=$(cd "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.." && pwd)

# Default the built-in plugins dir to repo's plugins/ if not already set. This
# is what makes `bin/goo` work straight out of a dev checkout. A production
# install would set COSMIC_GOO_BUILTIN_PLUGINS_DIR to /usr/share/cosmic-goo/plugins.
export COSMIC_GOO_BUILTIN_PLUGINS_DIR="${COSMIC_GOO_BUILTIN_PLUGINS_DIR:-$GOO_DIR/plugins}"

# shellcheck source=../lib/toml.sh
. "$GOO_DIR/lib/toml.sh"
# shellcheck source=../lib/types.sh
. "$GOO_DIR/lib/types.sh"
# shellcheck source=../lib/url-encode.sh
. "$GOO_DIR/lib/url-encode.sh"
# shellcheck source=../lib/selection.sh
. "$GOO_DIR/lib/selection.sh"
# shellcheck source=../lib/plugin-loader.sh
. "$GOO_DIR/lib/plugin-loader.sh"
# shellcheck source=../lib/verbs.sh
. "$GOO_DIR/lib/verbs.sh"
# shellcheck source=../lib/address.sh
. "$GOO_DIR/lib/address.sh"
# shellcheck source=../lib/dialog.sh
. "$GOO_DIR/lib/dialog.sh"

# ---------------- helpers ----------------

usage() {
    cat <<'EOF'
goo — Grammar Of Operations CLI

USAGE
    goo                                  Open the compose dialog (picker-driven)
    goo <verb> [POSITIONAL...] [--FLAG=VALUE]
    goo list <source>                    Emit source items as JSON
    goo describe <verb>                  Show verb details
    goo compose                          Pick subject → verb → object → adverbs
    goo plugins                          List loaded plugins
    goo validate                         Validate all loaded plugins

SUBJECT INFERENCE
    If no positional is given, the subject falls back in order:
      1. PRIMARY selection (wl-paste --primary)
      2. Clipboard (wl-paste)
      3. Focused app (cos-cli) when the verb accepts an app type

EXAMPLES
    goo critique "some text to review"
    goo critique --via=clipboard          # operate on the current selection
    goo plugins
    goo describe critique
EOF
}

die() {
    printf 'goo: %s\n' "$*" >&2
    exit 1
}

# Resolve a positional argument into a subject JSON. Heuristics:
#   - if the verb accepts text/*, treat the positional as text
#   - else, look up sources emitting an accepted type and find an item whose
#     id or title contains the positional (case-insensitive)
#   - if no positional, fall back to selection, then clipboard, then focused app
# Captured once in cmd_verb if stdin is piped (not a TTY). Empty otherwise.
STDIN_TEXT=""

resolve_subject() {
    local verb_json=$1 positional=${2:-}
    local accepts
    accepts=$(jq -r '.accepts[]?' <<<"$verb_json")

    accepts_text() {
        local p
        for p in $accepts; do
            mime_matches "$p" "text/plain" && return 0
        done
        return 1
    }

    # 1. Explicit positional (sigil or native shape) → the addressing resolver.
    if [ -n "$positional" ] && address_is_explicit "$positional"; then
        address_resolve "$positional" "$verb_json"
        return $?
    fi

    # 2. Bare positional.
    if [ -n "$positional" ]; then
        if accepts_text; then
            local mt
            mt=$(mime_detect_content "$positional")
            jq -nc --arg t "$mt" --arg text "$positional" '{type:$t, text:$text}'
            return 0
        fi
        # Handle resolution: walk sources emitting an accepted type, match input.
        local registry
        registry=$(plugin_load_all)
        local pattern source emits items match
        while IFS= read -r pattern; do
            while IFS= read -r source; do
                emits=$(jq -r '.emits // empty' <<<"$source")
                [ -z "$emits" ] && continue
                if mime_matches "$pattern" "$emits"; then
                    local list_cmd
                    list_cmd=$(jq -r '.list_cmd // empty' <<<"$source")
                    [ -z "$list_cmd" ] && continue
                    items=$(bash -c "$list_cmd" 2>/dev/null)
                    [ -z "$items" ] && continue
                    match=$(jq -c --arg q "$positional" --arg type "$emits" '
                        (try (. // []) catch []) | .[]?
                        | select(
                            (((.id    // "") | ascii_downcase) | contains($q | ascii_downcase))
                            or
                            (((.title // "") | ascii_downcase) | contains($q | ascii_downcase))
                          )
                        | . + {type: $type}
                    ' <<<"$items" 2>/dev/null | head -n 1)
                    if [ -n "$match" ]; then
                        printf '%s\n' "$match"
                        return 0
                    fi
                fi
            done < <(jq -c '.sources[]' <<<"$registry")
        done <<<"$accepts"
        die "could not resolve '$positional' against any source for verb's accepted types"
    fi

    # 3. No positional: implicit subject chain — stdin → selection → clipboard → focused app.
    if accepts_text; then
        local text mt
        if [ -n "$STDIN_TEXT" ]; then
            text=$STDIN_TEXT
        else
            text=$(selection_primary)
            [ -z "$text" ] && text=$(selection_clipboard)
        fi
        if [ -n "$text" ]; then
            mt=$(mime_detect_content "$text")
            jq -nc --arg t "$mt" --arg text "$text" '{type:$t, text:$text}'
            return 0
        fi
    fi
    # Non-text accepts: try focused app.
    local app
    app=$(focused_app 2>/dev/null | head -n 1)
    if [ -n "$app" ]; then
        printf '%s\n' "$app" | jq -c '. + {type:"application/vnd.cos-cli.app", id:.app_id, metadata:.}'
        return 0
    fi
    die "no subject provided and no implicit subject available (stdin/selection/clipboard/focused-app all empty)"
}

# ---------------- subcommand: plugins ----------------

cmd_plugins() {
    local registry
    registry=$(plugin_load_all)
    local count
    count=$(jq '.plugins | length' <<<"$registry")
    if [ "$count" -eq 0 ]; then
        printf '(no plugins loaded — check COSMIC_GOO_BUILTIN_PLUGINS_DIR=%s)\n' \
            "$COSMIC_GOO_BUILTIN_PLUGINS_DIR" >&2
        return 0
    fi
    jq -r '.plugins[] |
        "\(.name)" + (if .description then " — \(.description)" else "" end) +
        "\n  \(.file)"
    ' <<<"$registry"
}

# ---------------- subcommand: validate ----------------

cmd_validate() {
    local registry errors=0
    registry=$(plugin_load_all)

    # 1. Verbs may declare `accepts = []` (no subject required, like `lock`),
    #    but if they declare a pattern list it can't contain empty strings.
    while IFS= read -r verb_name; do
        [ -z "$verb_name" ] && continue
        printf 'verb "%s" has an empty accept pattern\n' "$verb_name" >&2
        errors=$((errors+1))
    done < <(jq -r '.verbs[] | select((.accepts // []) | any(. == "")) | .name' <<<"$registry")

    # 2. Adverbs declare scope (applies_to or applies_to_verbs).
    while IFS= read -r adverb_name; do
        [ -z "$adverb_name" ] && continue
        local has_scope
        has_scope=$(jq -r --arg n "$adverb_name" '
            (.adverbs[] | select(.name == $n))
            | (has("applies_to") or has("applies_to_verbs"))
        ' <<<"$registry")
        if [ "$has_scope" != "true" ]; then
            printf 'adverb "%s" has neither applies_to nor applies_to_verbs\n' "$adverb_name" >&2
            errors=$((errors+1))
        fi
    done < <(jq -r '.adverbs[]?.name' <<<"$registry")

    # 3. Selector adverbs that reference template_var or template values
    #    should at least have a values object.
    while IFS= read -r adverb; do
        local name kind has_values
        name=$(jq -r '.name' <<<"$adverb")
        kind=$(jq -r '.kind // "selector"' <<<"$adverb")
        has_values=$(jq -r '.values // {} | length' <<<"$adverb")
        if [ "$kind" = "selector" ] && [ "$has_values" = "0" ]; then
            printf 'selector adverb "%s" has no values\n' "$name" >&2
            errors=$((errors+1))
        fi
    done < <(jq -c '.adverbs[]?' <<<"$registry")

    # 4. Sigils: char must be a single char, must not be a core/native one
    #    (: + . / ~ or alphanumeric would break URL/path/text detection), and
    #    must have an expansion.
    while IFS= read -r sigil; do
        [ -z "$sigil" ] && continue
        local char expands
        char=$(jq -r '.char // ""' <<<"$sigil")
        expands=$(jq -r '.expands // ""' <<<"$sigil")
        if [ "${#char}" -ne 1 ]; then
            printf 'sigil "%s" must be exactly one character\n' "$char" >&2
            errors=$((errors+1))
        fi
        case "$char" in
            [a-zA-Z0-9]|:|+|.|/|'~')
                printf 'sigil "%s" collides with a reserved/native prefix (: + . / ~ alnum)\n' "$char" >&2
                errors=$((errors+1))
                ;;
        esac
        if [ -z "$expands" ]; then
            printf 'sigil "%s" has no expansion\n' "$char" >&2
            errors=$((errors+1))
        fi
    done < <(jq -c '.sigils[]?' <<<"$registry")

    if [ "$errors" -eq 0 ]; then
        printf 'goo validate: OK (%d plugins, %d types, %d sources, %d verbs, %d adverbs, %d sigils)\n' \
            "$(jq '.plugins | length' <<<"$registry")" \
            "$(jq '.types | length' <<<"$registry")" \
            "$(jq '.sources | length' <<<"$registry")" \
            "$(jq '.verbs | length' <<<"$registry")" \
            "$(jq '.adverbs | length' <<<"$registry")" \
            "$(jq '.sigils | length' <<<"$registry")"
        return 0
    fi
    printf 'goo validate: %d error(s)\n' "$errors" >&2
    return 1
}

# ---------------- subcommand: list ----------------

cmd_list() {
    local source_name=${1:-}
    [ -z "$source_name" ] && die "list: expected a source name"
    local registry source list_cmd
    registry=$(plugin_load_all)
    source=$(jq -c --arg n "$source_name" '.sources[] | select(.name == $n)' <<<"$registry")
    [ -z "$source" ] && die "list: no source named '$source_name'"
    list_cmd=$(jq -r '.list_cmd // empty' <<<"$source")
    [ -z "$list_cmd" ] && die "list: source '$source_name' has no list_cmd"
    bash -c "$list_cmd"
}

# ---------------- subcommand: describe ----------------

cmd_describe() {
    local verb_name=${1:-}
    [ -z "$verb_name" ] && die "describe: expected a verb name"
    local verb
    verb=$(verb_lookup "$verb_name") || die "describe: no verb named '$verb_name'"
    jq -r '
        "verb: \(.name)" +
        (if .description then "\ndescription: \(.description)" else "" end) +
        "\naccepts: \(.accepts | join(", "))" +
        (if .object_type then "\nobject_type: \(.object_type)" else "" end) +
        (if .default_for then "\ndefault_for: \(.default_for)" else "" end) +
        (if .uses_adverbs then "\nuses_adverbs: \(.uses_adverbs | join(", "))" else "" end) +
        (if .cmd then "\ncmd: \(.cmd)" else "" end) +
        (if .prompt then "\nprompt:\n  " + (.prompt | gsub("\n"; "\n  ")) else "" end) +
        (if .confirm then "\nconfirm: true" else "" end) +
        "\nprovided by plugin: \(._plugin)"
    ' <<<"$verb"
}

# ---------------- subcommand: __complete (for shell completions) ----------------
#
# Hidden surface. Bash/zsh completion scripts call this to get candidates for
# the various positions in a command line. Quiet on miss — must never error
# during TAB completion or it'll wedge the user's shell.

cmd_complete() {
    local stage=${1:-}
    local arg=${2:-}
    local registry
    registry=$(plugin_load_all 2>/dev/null) || return 0
    case "$stage" in
        subcommands)
            # static subcommands plus all verb names
            printf 'list\ndescribe\nplugins\nvalidate\ncompose\nhelp\n'
            jq -r '.verbs[]?.name' <<<"$registry"
            ;;
        verbs)
            jq -r '.verbs[]?.name' <<<"$registry"
            ;;
        sources)
            jq -r '.sources[]?.name' <<<"$registry"
            ;;
        adverbs)
            # arg is the verb name; emit adverbs the verb opts into.
            [ -z "$arg" ] && return 0
            jq -r --arg v "$arg" '
                .verbs[] | select(.name == $v) | (.uses_adverbs // [])[]
            ' <<<"$registry"
            ;;
        adverb-values)
            # arg is the adverb name; emit its selector values.
            [ -z "$arg" ] && return 0
            jq -r --arg a "$arg" '
                .adverbs[] | select(.name == $a) | (.values // {}) | keys[]
            ' <<<"$registry"
            ;;
        source-prefixes)
            # Emit `:prefix:` tokens for sources that declare a prefix, for
            # `goo VERB :<TAB>` completion (leading colon = source path).
            jq -r '.sources[] | select(.prefix) | ":" + .prefix + ":"' <<<"$registry"
            ;;
        sigils)
            # Emit registered customizable sigil chars (for docs / discovery).
            jq -r '.sigils[]?.char' <<<"$registry"
            ;;
        verb-accepts-handle)
            # "yes" if the verb accepts any non-text (handle) type; used to
            # decide whether bare-positional completion should list items.
            [ -z "$arg" ] && return 0
            jq -r --arg v "$arg" '
                .verbs[] | select(.name == $v)
                | (.accepts // [])
                | if any(test("^text/") | not) then "yes" else "no" end
            ' <<<"$registry" | head -n 1
            ;;
        verb-subject-items)
            # Emit ids from every source whose `emits` matches one of the
            # verb's accepted (handle) types. Runs list_cmds — used only for
            # explicit bare-positional completion of handle verbs.
            [ -z "$arg" ] && return 0
            local accepts pattern source emits list_cmd
            accepts=$(jq -r --arg v "$arg" '.verbs[] | select(.name == $v) | .accepts[]?' <<<"$registry")
            while IFS= read -r pattern; do
                [ -z "$pattern" ] && continue
                while IFS= read -r source; do
                    emits=$(jq -r '.emits // empty' <<<"$source")
                    [ -z "$emits" ] && continue
                    if mime_matches "$pattern" "$emits"; then
                        list_cmd=$(jq -r '.list_cmd // empty' <<<"$source")
                        [ -z "$list_cmd" ] && continue
                        bash -c "$list_cmd" 2>/dev/null | jq -r '.[]?.id // empty' 2>/dev/null
                    fi
                done < <(jq -c '.sources[] | select(.enumerate != false)' <<<"$registry")
            done <<<"$accepts"
            ;;
        source-items)
            # arg is a source name OR prefix; emit ids (one per line). Invokes
            # the source's list_cmd, which can be slow — used only for
            # explicit @source: completion.
            [ -z "$arg" ] && return 0
            local list_cmd
            # Select the first matching source inside jq so a multi-line
            # list_cmd survives intact (piping to `head -n1` would truncate it).
            list_cmd=$(jq -r --arg s "$arg" '
                [.sources[] | select(.name == $s or (.prefix // "") == $s)]
                | first | .list_cmd // empty
            ' <<<"$registry")
            [ -z "$list_cmd" ] && return 0
            bash -c "$list_cmd" 2>/dev/null | jq -r '.[]?.id // empty' 2>/dev/null
            ;;
        *)
            return 0
            ;;
    esac
}

# ---------------- subcommand: compose (picker-driven dialog) ----------------

# Emit subject candidates as "address<TAB>label" lines for the picker.
_compose_subject_candidates() {
    local registry
    registry=$(plugin_load_all)
    # Implicit text subjects first.
    local sel clip
    sel=$(selection_primary | head -c 60)
    clip=$(selection_clipboard | head -c 60)
    [ -n "$sel" ]  && printf ':sel:\tselection: %s\n' "$sel"
    [ -n "$clip" ] && printf ':clip:\tclipboard: %s\n' "$clip"
    # Enumerable sources with a prefix: list their items as :prefix:id.
    # Sources with `enumerate = false` are skipped here (too slow or too noisy
    # to bulk-list — e.g. bluetooth's timeout, the files flood, 750 clipboard
    # entries); they stay reachable on demand via :prefix:query.
    local source prefix name list_cmd
    while IFS= read -r source; do
        prefix=$(jq -r '.prefix // empty' <<<"$source")
        name=$(jq -r '.name' <<<"$source")
        [ -z "$prefix" ] && continue
        list_cmd=$(jq -r '.list_cmd // empty' <<<"$source")
        [ -z "$list_cmd" ] && continue
        bash -c "$list_cmd" 2>/dev/null | jq -r --arg p "$prefix" --arg s "$name" '
            .[]? | ":\($p):\(.id)\t\(.title // .id) (\($s))"
        ' 2>/dev/null
    done < <(jq -c '.sources[]
        | select(.enumerate != false)
        | select(.name != "selection" and .name != "clipboard")' <<<"$registry")
}

cmd_compose() {
    # 1. Subject.
    local subj_line subj_addr subject
    subj_line=$(_compose_subject_candidates | dialog_pick "Subject") || { echo "compose: cancelled" >&2; return 130; }
    subj_addr=${subj_line%%$'\t'*}        # strip the label after the tab
    subject=$(address_resolve "$subj_addr") || { echo "compose: could not resolve subject '$subj_addr'" >&2; return 1; }
    local subject_type
    subject_type=$(jq -r '.type // "text/plain"' <<<"$subject")

    # 2. Verb (filtered to those accepting the subject's type).
    local verbs verb_name verb
    verbs=$(verb_for_subject "$subject" | jq -r '.name' | sort -u)
    [ -z "$verbs" ] && { echo "compose: no verbs accept type $subject_type" >&2; return 1; }
    verb_name=$(printf '%s\n' "$verbs" | dialog_pick "Verb [$subject_type]") || { echo "compose: cancelled" >&2; return 130; }
    verb=$(verb_lookup "$verb_name") || { echo "compose: unknown verb '$verb_name'" >&2; return 1; }

    # 3. Object, if the verb takes one.
    local object=null object_type
    object_type=$(jq -r '.object_type // empty' <<<"$verb")
    if [ -n "$object_type" ]; then
        local obj_cands obj_line obj_addr
        obj_cands=$(_compose_subject_candidates | grep -F -- ":" || true)
        obj_line=$(printf '%s\n' "$obj_cands" | dialog_pick "Object [$object_type]") \
            || { echo "compose: cancelled" >&2; return 130; }
        obj_addr=${obj_line%%$'\t'*}
        object=$(address_resolve "$obj_addr") || { echo "compose: could not resolve object" >&2; return 1; }
    fi

    # 4. Adverbs the verb opts into (selector values; fills are typed).
    local adverbs='{}' aname avalue adverb kind
    while IFS= read -r aname; do
        [ -z "$aname" ] && continue
        adverb=$(jq -c --arg n "$aname" '.adverbs[] | select(.name==$n)' <<<"$(plugin_load_all)")
        [ -z "$adverb" ] && continue
        kind=$(jq -r '.kind // "selector"' <<<"$adverb")
        if [ "$kind" = "selector" ]; then
            avalue=$(jq -r '.values // {} | keys[]' <<<"$adverb" | dialog_pick "--$aname") || continue
        else
            avalue=$(printf '' | dialog_pick "--$aname (type a value)") || continue
        fi
        [ -n "$avalue" ] && adverbs=$(jq -c --arg n "$aname" --arg v "$avalue" '. + {($n): $v}' <<<"$adverbs")
    done < <(jq -r '.uses_adverbs[]?' <<<"$verb")

    # 5. Preview + confirm.
    local preview
    preview="goo $verb_name $subj_addr"
    [ "$object" != "null" ] && preview+=" <object>"
    local pairs
    pairs=$(jq -r 'to_entries[]? | "--\(.key)=\(.value)"' <<<"$adverbs" | tr '\n' ' ')
    [ -n "$pairs" ] && preview+=" ${pairs% }"
    if ! dialog_confirm "Run: $preview ?"; then
        echo "compose: cancelled" >&2
        return 130
    fi

    # 6. Execute through the same path the CLI uses.
    verb_apply "$verb" "$subject" "$object" "$adverbs"
}

# ---------------- verb invocation ----------------

cmd_verb() {
    local verb_name=$1
    shift
    local verb
    verb=$(verb_lookup "$verb_name") || die "unknown verb or subcommand: $verb_name (try 'goo plugins')"

    # Capture piped stdin once, before any subshell consumes it. A TTY means
    # interactive use (no piped input); only non-TTY stdin is treated as a
    # subject. F10-style hotkeys have no stdin and fall through to selection.
    if [ ! -t 0 ]; then
        STDIN_TEXT=$(cat)
    fi

    # Parse remaining args: positionals + --flag=val.
    local positionals=()
    local adverbs='{}'
    while [ $# -gt 0 ]; do
        case "$1" in
            --*=*)
                local kv=${1#--}
                local name=${kv%%=*}
                local value=${kv#*=}
                adverbs=$(jq --arg n "$name" --arg v "$value" '. + {($n): $v}' <<<"$adverbs")
                shift
                ;;
            --*)
                local name=${1#--}
                local value=${2:-}
                if [ -z "$value" ] || [[ "$value" == --* ]]; then
                    # No value -> treat as flag = true
                    adverbs=$(jq --arg n "$name" '. + {($n): true}' <<<"$adverbs")
                    shift
                else
                    adverbs=$(jq --arg n "$name" --arg v "$value" '. + {($n): $v}' <<<"$adverbs")
                    shift 2
                fi
                ;;
            *)
                positionals+=("$1")
                shift
                ;;
        esac
    done

    local subject_arg=${positionals[0]:-}
    local object_arg=${positionals[1]:-}

    local subject=null object=null
    local accepts_count
    accepts_count=$(jq '.accepts // [] | length' <<<"$verb")
    if [ "$accepts_count" -gt 0 ]; then
        subject=$(resolve_subject "$verb" "$subject_arg") || exit 1
    elif [ -n "$subject_arg" ]; then
        # Verb declares no accepts but a positional was given anyway. Treat as
        # text content so the template can still reference {subject.text}.
        subject=$(jq -nc --arg text "$subject_arg" '{type:"text/plain", text:$text}')
    fi
    if [ -n "$object_arg" ]; then
        # Treat object same way for now (text or via source lookup).
        object=$(resolve_subject "$verb" "$object_arg") || exit 1
    fi

    verb_apply "$verb" "$subject" "$object" "$adverbs"
}

# ---------------- dispatch ----------------

case "${1:-}" in
    ""|compose)        shift 2>/dev/null || true; cmd_compose "$@" ;;
    list)              shift; cmd_list "$@" ;;
    describe)          shift; cmd_describe "$@" ;;
    plugins)           shift; cmd_plugins "$@" ;;
    validate)          shift; cmd_validate "$@" ;;
    __complete)        shift; cmd_complete "$@" ;;
    -h|--help|help)    usage ;;
    *)                 cmd_verb "$@" ;;
esac
