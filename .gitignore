# Logs
*.log
recon/*.log
!recon/findings.md

# Editor / OS
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/

# Rust
/target/
crates/target/
**/*.rs.bk
# Cargo.lock IS committed: application workspace, not a published library
# (see doc/design/rust-port-scoping.md §5).

# Build artifacts
/dist/
/build/
# mkdocs build output (gitignore has no inline comments — keep it on its own line)
/site/

# Scratch / workspace for assistant sessions (test output, debug fixtures) —
# in-repo (not /tmp) so it travels with the checkout, but never committed.
.scratch/

# Local overrides
.cosmic-goo.local/
.env
.env.local

# Claude Code local settings (settings.json itself can be shared)
.claude/settings.local.json

# Runtime state (XDG_RUNTIME_DIR mirror, just in case)
/run/

# Session handoff log (local; resume notes for an assistant session)
SESSION-LOG.md

# Claude Code scheduled-tasks lock (runtime state)
.claude/scheduled_tasks.lock
